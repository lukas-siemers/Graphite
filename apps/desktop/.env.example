# Graphite desktop — Supabase credentials (Stage 4 sync wiring).
#
# Copy this to `apps/desktop/.env.local` and paste in the project's real
# URL + anon key. These values are client-safe: the anon key is designed
# to ship in client bundles and is gated by RLS server-side. The
# service-role key MUST NEVER live in this file — it is server-only and
# only referenced by Supabase Edge Functions.
#
# At runtime the Electron main process (apps/desktop/electron/main.ts)
# reads this file on startup and exposes the values to the renderer via
# an `env:getSupabaseConfig` IPC handler. Keys already set in
# process.env (CI, parent shell) are never overwritten by the file.
#
# Alternative: drop a `graphite.env` file in the Electron userData
# directory (macOS: ~/Library/Application Support/Graphite/; Windows:
# %APPDATA%\Graphite\; Linux: ~/.config/Graphite/) with the same format.
# The userData location takes precedence over .env.local so post-install
# overrides are possible without rebuilding the app.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
